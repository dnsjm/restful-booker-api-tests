{
  "name": "restful-booker-api-tests",
  "version": "1.0.0",
  "description": "API test suite for restful-booker — Playwright request fixtures, JSON-schema validation, full CRUD coverage, CI-ready.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --reporter=list",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "postman:newman": "newman run postman/restful-booker.postman_collection.json"
  },
  "keywords": [
    "playwright",
    "api-testing",
    "qa",
    "sdet",
    "restful-booker",
    "json-schema",
    "ajv",
    "contract-testing"
  ],
  "author": "JM Dionisio (@dnsjm)",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "newman": "^6.2.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
