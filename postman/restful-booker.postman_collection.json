{
  "info": {
    "name": "Restful Booker API",
    "description": "Companion Postman collection mirroring the Playwright suite. Run with: npm run postman:newman",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "rb-jm-dionisio-portfolio"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://restful-booker.herokuapp.com" },
    { "key": "token", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /ping",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/ping", "host": ["{{baseUrl}}"], "path": ["ping"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth", "host": ["{{baseUrl}}"], "path": ["auth"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('returns a token', () => pm.expect(body.token).to.be.a('string'));",
                  "pm.collectionVariables.set('token', body.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "POST /booking (create)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"JM\",\n  \"lastname\": \"Dionisio\",\n  \"totalprice\": 250,\n  \"depositpaid\": true,\n  \"bookingdates\": { \"checkin\": \"2026-06-01\", \"checkout\": \"2026-06-05\" },\n  \"additionalneeds\": \"Late check-in\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/booking", "host": ["{{baseUrl}}"], "path": ["booking"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has bookingid', () => pm.expect(body.bookingid).to.be.a('number'));",
                  "pm.collectionVariables.set('bookingId', body.bookingid);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /booking/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('firstname is JM', () => pm.expect(body.firstname).to.eql('JM'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "PATCH /booking/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{ \"firstname\": \"Patched\" }" },
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('firstname updated', () => pm.expect(pm.response.json().firstname).to.eql('Patched'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "DELETE /booking/:id",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Cookie", "value": "token={{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
